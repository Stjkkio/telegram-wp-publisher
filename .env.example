# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_authorized_chat_id

# ── AI Provider ───────────────────────────────────────────────────────────────
# Set AI_PROVIDER to "openai" or "anthropic". Set ONLY the corresponding API key.
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── WordPress ─────────────────────────────────────────────────────────────────
WP_URL=https://your-site.com
WP_USER=your_wp_api_user
WP_AUTH_KEY=xxxx xxxx xxxx xxxx xxxx xxxx
HMAC_SECRET=replace_with_a_long_random_secret_min_32_chars

# ── Authors (optional) ────────────────────────────────────────────────────────
# Comma-separated list of Name:WP_User_ID pairs.
# Find your WP User ID in WP Admin → Users → your profile (check the URL: ?user_id=N).
# If only one entry: used automatically, no selection button shown.
# If multiple entries: a "👤 Name ▾" button appears on the preview to choose.
# Leave unset to post as the API user.
# WP_AUTHORS=Alice:5,Editorial:3

# ── Server-level HTTP auth (optional) ─────────────────────────────────────────
# Only needed when your hosting provider places HTTP Basic Auth in front of
# WordPress at the server level (e.g. a staging environment protected by
# server-side Basic Auth, separate from WP Application Passwords).
# When set, the bot sends these as the Authorization header and puts WP
# Application Password credentials into X-Bot-Credential.
# Leave unset for standard WordPress installations.
# WP_SERVER_HTTP_USER=staging_user
# WP_SERVER_HTTP_PASS=staging_password

# ── Environment ───────────────────────────────────────────────────────────────
# staging  → DEFAULT_POST_STATUS must be "draft"
# production → DEFAULT_POST_STATUS must be "publish"
NODE_ENV=staging
DEFAULT_POST_STATUS=draft

# ── Tuning ────────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SECONDS=300

# Seconds to wait after the last received image before triggering AI processing.
# Increase if you need more time to select and send a photo album (default: 30).
IMAGE_WAIT_SECONDS=30

HTTP_TIMEOUT_MS=30000
MAX_RETRIES=3
MAX_IMAGES_PER_SESSION=10
MAX_IMAGE_SIZE_MB=15
LOG_LEVEL=info
